{
  "title": "Get Stack LED Response",
  "type": "object",
  "description": "Returns the current stack LED state.",
  "properties": {
    "command": {
      "type": "string",
      "enum": [
        "get_stackled"
      ],
      "example": "get_stackled"
    },
    "command_id": {
      "type": "string",
      "example": "stackled-get-001"
    },
    "response": {
      "type": "string",
      "enum": [
        "success",
        "failure"
      ],
      "example": "success"
    },
    "payload": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "status": {
              "type": "string",
              "example": "NON_DEFAULT"
            },
            "color": {
              "type": "string",
              "example": "amber"
            },
            "brightness": {
              "type": "string",
              "example": "high"
            },
            "flash": {
              "type": "boolean",
              "example": true
            },
            "seconds": {
              "type": "integer",
              "example": 0
            },
            "seconds_remaining": {
              "type": "integer",
              "example": 14
            }
          }
        },
        {
          "title": "failure",
          "type": "object",
          "description": "description of the error",
          "examples": [
            {
              "code": 1,
              "message": "invalid payload for version api. expected empty payload"
            }
          ],
          "properties": {
            "code": {
              "type": "integer",
              "description": "The error code",
              "example": 1,
              "enum": [
                1,
                2,
                3,
                6,
                7
              ]
            },
            "message": {
              "type": "string",
              "description": "A brief description of the error"
            }
          },
          "required": [
            "code",
            "message"
          ]
        }
      ]
    }
  },
  "required": [
    "command",
    "command_id",
    "response",
    "payload"
  ],
  "examples": [
    {
      "command": "get_stackled",
      "command_id": "stackled-get-001",
      "response": "success",
      "payload": {
        "status": "NON_DEFAULT",
        "color": "amber",
        "brightness": "high",
        "flash": true,
        "seconds": 0,
        "seconds_remaining": 14
      }
    }
  ]
}
