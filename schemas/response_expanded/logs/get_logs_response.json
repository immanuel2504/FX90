{
  "title": "Get Logs",
  "x-stoplight": {
    "id": "tixd44yqi3h2o"
  },
  "type": "object",
  "description": "Get the Logging configuration on the reader",
  "properties": {
    "command": {
      "type": "string",
      "enum": [
        "get_logs"
      ],
      "example": "get_logs",
      "description": "The value for the key command must be get_logs"
    },
    "command_id": {
      "type": "string",
      "example": "a2134",
      "description": "A unique ID that will be echoed back in the command response by the reader."
    },
    "response": {
      "type": "string",
      "enum": [
        "success",
        "failure"
      ],
      "example": "success"
    },
    "payload": {
      "oneOf": [
        {
          "title": "success",
          "type": "object",
          "description": "Reader Logging Configuration",
          "properties": {
            "radioPacketLog": {
              "type": "boolean",
              "description": "Indicates whether radio packet logging is enabled."
            },
            "components": {
              "type": "array",
              "description": "Log level configuration per reader subcomponent.",
              "items": {
                "type": "object",
                "properties": {
                  "componentName": {
                    "type": "string",
                    "example": "RC",
                    "description": "Name of subcomponent. For radio_control, only the INFO log level is supported. For reader_gateway, supported log levels are INFO, DEBUG, WARNING, and ERROR.",
                    "enum": [
                      "radio_control",
                      "reader_gateway"
                    ]
                  },
                  "level": {
                    "type": "string",
                    "enum": [
                      "DEBUG",
                      "INFO",
                      "WARNING",
                      "ERROR"
                    ],
                    "description": "Logging Level"
                  }
                },
                "required": [
                  "componentName",
                  "level"
                ]
              }
            }
          }
        },
        {
          "title": "failure",
          "type": "object",
          "description": "description of the error",
          "examples": [
            {
              "code": 1,
              "message": "invalid payload for version api. expected empty payload"
            }
          ],
          "properties": {
            "code": {
              "type": "integer",
              "description": "The error code",
              "example": 1,
              "enum": [
                1,
                2,
                3,
                6,
                7
              ]
            },
            "message": {
              "type": "string",
              "description": "A brief description of the error"
            }
          },
          "required": [
            "code",
            "message"
          ]
        }
      ]
    }
  },
  "required": [
    "command",
    "command_id"
  ]
}
