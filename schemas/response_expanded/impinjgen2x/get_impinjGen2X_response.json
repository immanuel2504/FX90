{
  "title": "Get Impinj Gen2X Configuration Response",
  "type": "object",
  "description": "Returns the current Impinj Gen2X feature configuration.",
  "properties": {
    "command": {
      "type": "string",
      "enum": [
        "get_impinjGen2X"
      ],
      "example": "get_impinjGen2X"
    },
    "command_id": {
      "type": "string",
      "example": "gen2x-get-001"
    },
    "response": {
      "type": "string",
      "enum": [
        "success",
        "failure"
      ],
      "example": "success"
    },
    "payload": {
      "oneOf": [
        {
          "type": "object",
          "description": "Current Impinj Gen2X feature configuration as last saved via set_impinjGen2X. Returns an empty object if no Gen2X configuration has been set yet. Only feature objects that were previously configured are included in the response.",
          "properties": {
            "fastID": {
              "type": "object",
              "description": "FastID configuration. Present only if fastID was previously configured.",
              "properties": {
                "enabled": {
                  "type": "boolean",
                  "description": "Whether FastID is enabled.",
                  "example": true
                },
                "tidSelector": {
                  "type": "string",
                  "description": "TID word selector mask, if one was configured.",
                  "enum": [
                    "TID[0]",
                    "TID[1]",
                    "TID[2]",
                    "TID[3]"
                  ],
                  "example": "TID[0]"
                }
              },
              "required": [
                "enabled"
              ]
            },
            "tagProtect": {
              "type": "object",
              "description": "TagProtect configuration. Present only if tagProtect was previously configured.",
              "properties": {
                "action": {
                  "type": "string",
                  "description": "Last configured protection action.",
                  "enum": [
                    "enableTagProtection",
                    "disableTagProtection",
                    "enableTagVisibility",
                    "disableTagVisibility"
                  ],
                  "example": "enableTagProtection"
                },
                "password": {
                  "type": "string",
                  "description": "8-character hexadecimal 32-bit password.",
                  "minLength": 8,
                  "maxLength": 8,
                  "pattern": "^[0-9A-Fa-f]{8}$",
                  "example": "77777777"
                },
                "tagID": {
                  "type": "string",
                  "description": "Hexadecimal tagID (EPC) of the target tag. Only present when action is enableTagProtection or disableTagProtection.",
                  "pattern": "^[0-9A-Fa-f]+$",
                  "example": "e2801191a5030069073b426d"
                },
                "enableShortRange": {
                  "type": "boolean",
                  "description": "Whether short-range protection mode is enabled.",
                  "example": true
                }
              },
              "required": [
                "action",
                "password"
              ]
            },
            "tagFocus": {
              "type": "object",
              "description": "TagFocus configuration. Present only if tagFocus was previously configured.",
              "properties": {
                "enabled": {
                  "type": "boolean",
                  "description": "Whether TagFocus is enabled.",
                  "example": true
                }
              },
              "required": [
                "enabled"
              ]
            },
            "tagQuieting": {
              "type": "object",
              "description": "Impinj TagQuieting configuration. Exactly one of basic or advanced must be provided.",
              "oneOf": [
                {
                  "required": [
                    "basic"
                  ]
                },
                {
                  "required": [
                    "advanced"
                  ]
                }
              ],
              "properties": {
                "basic": {
                  "type": "object",
                  "description": "Basic TagQuieting configuration for quieting or unquieting specific tags identified by EPC.",
                  "properties": {
                    "action": {
                      "type": "string",
                      "description": "quiet silences the specified tags for the current inventory round; unquiet restores previously quieted tags.",
                      "enum": [
                        "quiet",
                        "unquiet"
                      ],
                      "example": "quiet"
                    },
                    "tagIDs": {
                      "type": "array",
                      "description": "Non-empty list of hexadecimal EPC strings identifying the tags to quiet or unquiet.",
                      "minItems": 1,
                      "items": {
                        "type": "string",
                        "pattern": "^[0-9A-Fa-f]+$",
                        "example": "e2801191a5030069073b426d"
                      }
                    }
                  },
                  "required": [
                    "action",
                    "tagIDs"
                  ]
                },
                "advanced": {
                  "type": "object",
                  "description": "Advanced TagQuieting configuration using Impinj Gen2X proprietary features.",
                  "properties": {
                    "preSelect": {
                      "type": "array",
                      "description": "Optional array of SELECT operations to position tags into specific session states before applying state-aware SELECT. Maximum 31 items allowed.",
                      "maxItems": 31,
                      "items": {
                        "type": "object",
                        "properties": {
                          "target": {
                            "type": "string",
                            "description": "Session or flag to target.",
                            "enum": [
                              "S0",
                              "S1",
                              "S2",
                              "S3",
                              "SL"
                            ],
                            "example": "S2"
                          },
                          "action": {
                            "type": "string",
                            "description": "Action to perform on the target session or flag.",
                            "enum": [
                              "ASSERTSL_NOTHING",
                              "DEASSERTSL_NOTHING",
                              "ASSERTSL_ASSERTSL",
                              "ASSERTSL_DEASSERTSL",
                              "DEASSERTSL_ASSERTSL",
                              "DEASSERTSL_DEASSERTSL",
                              "NEGSL_NOTHING",
                              "NOTHING_ASSERTSL",
                              "NOTHING_DEASSERTSL",
                              "NOTHING_NEGSL",
                              "INVA_NOTHING",
                              "INVB_NOTHING",
                              "INVA_INVB",
                              "INVB_INVA",
                              "INVA_INVA",
                              "INVB_INVB",
                              "NOTHING_INVA",
                              "NOTHING_INVB"
                            ],
                            "example": "INVB_INVA"
                          },
                          "mask": {
                            "type": "object",
                            "description": "Memory mask for tag selection.",
                            "properties": {
                              "bank": {
                                "type": "string",
                                "description": "Memory bank to match against.",
                                "enum": [
                                  "EPC",
                                  "TID",
                                  "USER",
                                  "RESERVED"
                                ],
                                "example": "EPC"
                              },
                              "pointer": {
                                "type": "integer",
                                "description": "Bit offset in memory bank.",
                                "minimum": 0,
                                "maximum": 65535,
                                "example": 32
                              },
                              "length": {
                                "type": "integer",
                                "description": "Number of bits to match.",
                                "minimum": 1,
                                "maximum": 255,
                                "example": 96
                              },
                              "value": {
                                "type": "string",
                                "description": "Hex string value to match (even length, valid hex characters).",
                                "pattern": "^[0-9A-Fa-f]+$",
                                "example": "A55E551ABE1C0DE869C7A459"
                              }
                            },
                            "required": [
                              "bank",
                              "pointer",
                              "length",
                              "value"
                            ]
                          }
                        },
                        "required": [
                          "target",
                          "action",
                          "mask"
                        ]
                      }
                    },
                    "tagQuietMasks": {
                      "type": "array",
                      "description": "Session-state combinations to check in TID memory. Minimum 1, maximum 3 items. No duplicate session prefixes allowed (e.g., S0A and S0B together).",
                      "minItems": 1,
                      "maxItems": 3,
                      "uniqueItems": true,
                      "items": {
                        "type": "string",
                        "enum": [
                          "S0A",
                          "S0B",
                          "S2A",
                          "S2B",
                          "S3A",
                          "S3B",
                          "SL_ASSERT",
                          "SL_DEASSERT"
                        ],
                        "example": "S0A"
                      }
                    },
                    "target": {
                      "type": "string",
                      "description": "Which flag to manipulate based on state check.",
                      "enum": [
                        "SL",
                        "S0",
                        "S1",
                        "S2",
                        "S3"
                      ],
                      "example": "SL"
                    },
                    "stateAwareAction": {
                      "type": "string",
                      "description": "Action to perform on target flag when tags match the tagQuietMasks pattern.",
                      "enum": [
                        "ASSERTSL",
                        "DEASSERTSL",
                        "ASSERTSL_DEASSERTSL",
                        "DEASSERTSL_ASSERTSL",
                        "NEGSL",
                        "NOT_DEASSERTSL",
                        "NOT_ASSERTSL",
                        "NOT_NEGSL",
                        "INV_A",
                        "INV_B",
                        "INV_A_NOT_INV_B",
                        "INV_B_NOT_INV_A",
                        "INV_A2BB2A",
                        "NOT_INV_B",
                        "NOT_INV_A",
                        "NOT_INV_A2BB2A"
                      ],
                      "example": "ASSERTSL"
                    }
                  },
                  "required": [
                    "tagQuietMasks",
                    "target",
                    "stateAwareAction"
                  ]
                }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        },
        {
          "title": "failure",
          "type": "object",
          "description": "description of the error",
          "examples": [
            {
              "code": 1,
              "message": "invalid payload for version api. expected empty payload"
            }
          ],
          "properties": {
            "code": {
              "type": "integer",
              "description": "The error code",
              "example": 1,
              "enum": [
                1,
                2,
                3,
                6,
                7
              ]
            },
            "message": {
              "type": "string",
              "description": "A brief description of the error"
            }
          },
          "required": [
            "code",
            "message"
          ]
        }
      ]
    }
  },
  "required": [
    "command",
    "command_id",
    "response",
    "payload"
  ],
  "examples": [
    {
      "command": "get_impinjGen2X",
      "command_id": "gen2x-get-001",
      "response": "success",
      "payload": {
        "fastID": {
          "enabled": true,
          "tidSelector": "TID[0]"
        }
      }
    }
  ]
}
