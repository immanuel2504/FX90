{
  "title": "Set GPO",
  "x-stoplight": {
    "id": "gfaepkncr3sor"
  },
  "type": "object",
  "description": "Sets the specified GPO on the reader to the value specified.",
  "properties": {
    "command": {
      "type": "string",
      "enum": [
        "set_gpo"
      ],
      "example": "set_gpo",
      "description": "The value for the key command must be set_gpo\n\nNote :\u00a0\nMaximum number of ports available per device type\n1. FX7500 = 3 GPO pins\n2. FX9600 = 4 GPO pins\n3. ATR7000 = 3 GPO pins"
    },
    "command_id": {
      "type": "string",
      "example": "abcd1324",
      "description": "A unique ID that will be echoed back in the command response by the reader."
    },
    "response": {
      "type": "string",
      "enum": [
        "success",
        "failure"
      ],
      "example": "success"
    },
    "payload": {
      "oneOf": [
        {
          "title": "success",
          "type": "object",
          "description": "Updates GPO port state"
        },
        {
          "title": "failure",
          "type": "object",
          "description": "description of the error",
          "examples": [
            {
              "code": 1,
              "message": "invalid payload for version api. expected empty payload"
            }
          ],
          "properties": {
            "code": {
              "type": "integer",
              "description": "The error code",
              "example": 1,
              "enum": [
                1,
                2,
                3,
                6,
                7
              ]
            },
            "message": {
              "type": "string",
              "description": "A brief description of the error"
            }
          },
          "required": [
            "code",
            "message"
          ]
        }
      ]
    }
  },
  "required": [
    "command",
    "command_id",
    "response"
  ]
}
