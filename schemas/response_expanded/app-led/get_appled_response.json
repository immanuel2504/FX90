{
  "title": "Get App LED",
  "x-stoplight": {
    "id": "nqbba6azh7cuy"
  },
  "type": "object",
  "description": "Retrieves the status of the app LED on the reader",
  "properties": {
    "command": {
      "type": "string",
      "enum": [
        "get_appled"
      ],
      "example": "get_appled",
      "description": "The value for the key command must be get_appled"
    },
    "command_id": {
      "type": "string",
      "description": "A unique ID that will be echoed back in the command response by the reader."
    },
    "response": {
      "type": "string",
      "enum": [
        "success",
        "failure"
      ],
      "example": "success"
    },
    "payload": {
      "oneOf": [
        {
          "title": "success",
          "type": "object",
          "description": "Represents current userapp led status",
          "properties": {
            "status": {
              "type": "string",
              "enum": [
                "DEFAULT",
                "NOT_DEFAULT"
              ],
              "example": "DEFAULT",
              "default": "DEFAULT"
            }
          },
          "required": [
            "status"
          ]
        },
        {
          "title": "failure",
          "type": "object",
          "description": "description of the error",
          "examples": [
            {
              "code": 1,
              "message": "invalid payload for version api. expected empty payload"
            }
          ],
          "properties": {
            "code": {
              "type": "integer",
              "description": "The error code",
              "example": 1,
              "enum": [
                1,
                2,
                3,
                6,
                7
              ]
            },
            "message": {
              "type": "string",
              "description": "A brief description of the error"
            }
          },
          "required": [
            "code",
            "message"
          ]
        }
      ]
    }
  },
  "required": [
    "command",
    "command_id",
    "response"
  ]
}
