{
  "title": "Set Passthru Response",
  "type": "object",
  "description": "Returns the pass-through command result.",
  "properties": {
    "command": {
      "type": "string",
      "enum": [
        "set_passthru"
      ],
      "example": "set_passthru"
    },
    "command_id": {
      "type": "string",
      "example": "passthru-set-001"
    },
    "response": {
      "type": "string",
      "enum": [
        "success",
        "failure"
      ],
      "example": "success"
    },
    "payload": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "response": {
              "type": "string",
              "example": "Success: radioPacketLog: OFF"
            }
          }
        },
        {
          "title": "failure",
          "type": "object",
          "description": "description of the error",
          "examples": [
            {
              "code": 1,
              "message": "invalid payload for version api. expected empty payload"
            }
          ],
          "properties": {
            "code": {
              "type": "integer",
              "description": "The error code",
              "example": 1,
              "enum": [
                1,
                2,
                3,
                6,
                7
              ]
            },
            "message": {
              "type": "string",
              "description": "A brief description of the error"
            }
          },
          "required": [
            "code",
            "message"
          ]
        }
      ]
    }
  },
  "required": [
    "command",
    "command_id",
    "response",
    "payload"
  ],
  "examples": [
    {
      "command": "set_passthru",
      "command_id": "passthru-set-001",
      "response": "success",
      "payload": {
        "response": "Success: radioPacketLog: OFF"
      }
    }
  ]
}
