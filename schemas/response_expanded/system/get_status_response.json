                  ],
                  "properties": {
                    "total": {
                      "type": "integer",
                      "description": "Total RAM in bytes",
                      "example": "26098076"
                    },
                    "free": {
                      "type": "integer",
                      "description": "Free RAM in bytes",
                      "example": "195612672"
                    },
                    "used": {
                      "type": "integer",
                      "description": "Used RAM in bytes",
                      "example": "65368064"
                    }
                  }
                }
              }
