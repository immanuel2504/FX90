{
  "title": "Set hostname",
  "x-stoplight": {
    "id": "set_hostname_resp"
  },
  "type": "object",
  "description": "Sets the hostname of the reader",
  "examples": [
    {
      "command": "set_hostname",
      "command_id": "abcd345",
      "response": "success",
      "payload": {}
    }
  ],
  "properties": {
    "command": {
      "type": "string",
      "enum": [
        "set_hostname"
      ],
      "description": "The value for the key command must be set_hostname"
    },
    "command_id": {
      "type": "string",
      "description": "A unique ID that will be echoed back in the command response by the reader."
    },
    "response": {
      "type": "string",
      "enum": [
        "success",
        "failure"
      ]
    },
    "payload": {
      "oneOf": [
        {
          "title": "success",
          "type": "object",
          "description": "Updates the reader hostname"
        },
        {
          "title": "failure",
          "type": "object",
          "description": "description of the error",
          "examples": [
            {
              "code": 1,
              "message": "invalid payload for version api. expected empty payload"
            }
          ],
          "properties": {
            "code": {
              "type": "integer",
              "description": "The error code",
              "example": 1,
              "enum": [
                1,
                2,
                3,
                6,
                7
              ]
            },
            "message": {
              "type": "string",
              "description": "A brief description of the error"
            }
          },
          "required": [
            "code",
            "message"
          ]
        }
      ]
    }
  },
  "required": [
    "command",
    "command_id",
    "response"
  ]
}
