{
  "title": "Start RFID Inventory or BLE scan Response",
  "x-stoplight": {
    "id": "2ck6qflak1zlw"
  },
  "type": "object",
  "description": "Acknowledges the start of an RFID inventory, BLE scanning, or dual scan operation.",
  "properties": {
    "command": {
      "type": "string",
      "enum": [
        "start"
      ],
      "example": "start",
      "description": "The value for the key command must be start."
    },
    "command_id": {
      "type": "string",
      "example": "req-001",
      "description": "A unique ID that will be echoed back in the command response by the reader."
    },
    "response": {
      "type": "string",
      "enum": [
        "success",
        "failure"
      ],
      "example": "success",
      "description": "Status of the execution request."
    },
    "payload": {
      "oneOf": [
        {
          "title": "StartResponsePayload",
          "type": "object",
          "description": "An empty object indicating that the RFID inventory, BLE scanning,  or dual scan operation has successfully started.\n",
          "properties": {}
        },
        {
          "title": "failure",
          "type": "object",
          "description": "description of the error",
          "examples": [
            {
              "code": 1,
              "message": "invalid payload for version api. expected empty payload"
            }
          ],
          "properties": {
            "code": {
              "type": "integer",
              "description": "The error code",
              "example": 1,
              "enum": [
                1,
                2,
                3,
                6,
                7
              ]
            },
            "message": {
              "type": "string",
              "description": "A brief description of the error"
            }
          },
          "required": [
            "code",
            "message"
          ]
        }
      ]
    }
  },
  "required": [
    "command",
    "command_id",
    "response",
    "payload"
  ],
  "examples": [
    {
      "command": "start",
      "command_id": "req-001",
      "response": "success",
      "payload": {}
    }
  ]
}
