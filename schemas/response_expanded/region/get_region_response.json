{
  "title": "Get Region",
  "x-stoplight": {
    "id": "lmxizdjjhg0nt"
  },
  "type": "object",
  "description": "Represents the active region and regulatory configuration.",
  "examples": [
    {
      "command": "get_region",
      "command_id": "a1b2c3345",
      "payload": {
        "FrequencyHopping": true,
        "channelData": [
          "915750",
          "915250",
          "903250"
        ],
        "country": "Canada",
        "lbtEnabled": false,
        "maxTxPowerSupported": 300,
        "minTxPowerSupported": 0,
        "region": "FCC_Generic",
        "regulatoryStandard": "CANADA_FCC_15"
      },
      "response": "success"
    }
  ],
  "properties": {
    "command": {
      "type": "string",
      "enum": [
        "get_region"
      ],
      "example": "get_region",
      "description": "The value for the key command must be get_region"
    },
    "command_id": {
      "type": "string",
      "example": "a1b2c3345",
      "description": "A unique ID that will be echoed back in the command response by the reader."
    },
    "response": {
      "type": "string",
      "enum": [
        "success",
        "failure"
      ],
      "example": "success"
    },
    "payload": {
      "oneOf": [
        {
          "title": "success",
          "type": "object",
          "description": "Represents the active region and regulatory configuration.",
          "examples": [
            {
              "FrequencyHopping": true,
              "channelData": [
                "915750",
                "915250",
                "903250"
              ],
              "country": "Canada",
              "lbtEnabled": false,
              "maxTxPowerSupported": 300,
              "minTxPowerSupported": 0,
              "region": "FCC_Generic",
              "regulatoryStandard": "CANADA_FCC_15"
            }
          ],
          "properties": {
            "FrequencyHopping": {
              "type": "boolean",
              "description": "Whether frequency hopping is enabled for the active regulatory standard.",
              "example": true,
              "default": true
            },
            "channelData": {
              "type": "array",
              "description": "Enabled RF channel list for the active region configuration.",
              "example": [
                "915750",
                "915250",
                "903250"
              ],
              "items": {
                "type": "string"
              }
            },
            "country": {
              "type": "string",
              "description": "Country name associated with the active region configuration.",
              "example": "Canada"
            },
            "lbtEnabled": {
              "type": "boolean",
              "description": "Whether Listen Before Talk (LBT) is enabled for the active region configuration.",
              "example": false,
              "default": false
            },
            "maxTxPowerSupported": {
              "type": "integer",
              "description": "Maximum transmit power supported by the reader for the active region.",
              "example": 300
            },
            "minTxPowerSupported": {
              "type": "integer",
              "description": "Minimum transmit power supported by the reader for the active region.",
              "example": 0
            },
            "region": {
              "type": "string",
              "description": "RF region code currently configured on the reader.",
              "example": "FCC_Generic"
            },
            "regulatoryStandard": {
              "type": "string",
              "description": "Regulatory standard currently applied for the configured region.",
              "example": "CANADA_FCC_15"
            }
          },
          "required": [
            "FrequencyHopping",
            "channelData",
            "country",
            "lbtEnabled",
            "maxTxPowerSupported",
            "minTxPowerSupported",
            "region",
            "regulatoryStandard"
          ]
        },
        {
          "title": "failure",
          "type": "object",
          "description": "description of the error",
          "examples": [
            {
              "code": 1,
              "message": "invalid payload for version api. expected empty payload"
            }
          ],
          "properties": {
            "code": {
              "type": "integer",
              "description": "The error code",
              "example": 1,
              "enum": [
                1,
                2,
                3,
                6,
                7
              ]
            },
            "message": {
              "type": "string",
              "description": "A brief description of the error"
            }
          },
          "required": [
            "code",
            "message"
          ]
        }
      ]
    }
  },
  "required": [
    "command",
    "command_id",
    "response"
  ]
}
