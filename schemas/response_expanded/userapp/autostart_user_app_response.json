{
  "title": "Auto Start User App",
  "x-stoplight": {
    "id": "ketpc00n4npmb"
  },
  "type": "object",
  "description": "Enables/Disables the Auto start for User App",
  "properties": {
    "command": {
      "type": "string",
      "enum": [
        "autostart_user_app"
      ],
      "example": "autostart_user_app",
      "description": "The value for the key command must be autostart_user_app"
    },
    "command_id": {
      "type": "string",
      "example": "abcd1234",
      "description": "A unique ID that will be echoed back in the command response by the reader."
    },
    "response": {
      "type": "string",
      "enum": [
        "success",
        "failure"
      ],
      "example": "success"
    },
    "payload": {
      "oneOf": [
        {
          "title": "success",
          "type": "object",
          "description": "configure auto start settings for userapp"
        },
        {
          "title": "failure",
          "type": "object",
          "description": "description of the error",
          "examples": [
            {
              "code": 1,
              "message": "invalid payload for version api. expected empty payload"
            }
          ],
          "properties": {
            "code": {
              "type": "integer",
              "description": "The error code",
              "example": 1,
              "enum": [
                1,
                2,
                3,
                6,
                7
              ]
            },
            "message": {
              "type": "string",
              "description": "A brief description of the error"
            }
          },
          "required": [
            "code",
            "message"
          ]
        }
      ]
    }
  },
  "required": [
    "command",
    "command_id",
    "response"
  ]
}
