{
  "title": "Set eSIM Configuration",
  "type": "object",
  "description": "Sets the eSIM configuration.",
  "properties": {
    "command": {
      "type": "string",
      "enum": [
        "set_eSimConfig"
      ],
      "example": "set_eSimConfig",
      "description": "The value for the key command must be set_eSimConfig"
    },
    "command_id": {
      "type": "string",
      "example": "esim-set-001",
      "description": "A unique ID that will be echoed back in the command response by the reader."
    },
    "payload": {
      "type": "object",
      "properties": {
        "operation": {
          "type": "string",
          "description": "eSIM profile operation to perform.",
          "enum": [
            "add",
            "delete",
            "enable",
            "disable"
          ],
          "example": "enable"
        },
        "profileNickName": {
          "type": "string",
          "description": "Nickname of the eSIM profile to apply the operation to.",
          "example": "gnd1"
        },
        "activationID": {
          "type": "string",
          "description": "Activation code/ID for provisioning a new eSIM profile. Required only when `operation` is `add`. Must be omitted for `enable`, `disable`, and `delete`.",
          "example": "LPA:1$RSP.GSMA.COM$ABCDEF1234567890"
        }
      },
      "required": [
        "operation",
        "profileNickName"
      ]
    }
  },
  "required": [
    "command",
    "command_id",
    "payload"
  ],
  "examples": [
    {
      "command": "set_eSimConfig",
      "command_id": "esim-set-001",
      "payload": {
        "operation": "enable",
        "profileNickName": "gnd1"
      }
    },
    {
      "command": "set_eSimConfig",
      "command_id": "esim-set-001",
      "payload": {
        "operation": "add",
        "profileNickName": "gnd1",
        "activationID": "LPA:1$RSP.GSMA.COM$ABCDEF1234567890"
      }
    },
    {
      "command": "set_eSimConfig",
      "command_id": "esim-set-001",
      "payload": {
        "operation": "delete",
        "profileNickName": "gnd1"
      }
    }
  ]
}
