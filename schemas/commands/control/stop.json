{
  "title": "Stop RFID Inventory or BLE scan",
  "type": "object",
  "description": "Stop RFID inventory, BLE scanning, or both.",
  "properties": {
    "command": {
      "type": "string",
      "enum": [
        "stop"
      ],
      "description": "Command name. Must be 'stop'."
    },
    "command_id": {
      "type": "string",
      "description": "A unique ID that will be echoed back in the command response by the reader.",
      "example": "req-001"
    },
    "payload": {
      "$ref": "../../references/request_payload/stop-2.yaml"
    }
  },
  "required": [
    "command",
    "command_id",
    "payload"
  ],
  "examples": [
    {
      "command": "stop",
      "command_id": "req-001",
      "payload": {}
    },
    {
      "command": "stop",
      "command_id": "req-001",
      "payload": {
        "scanType": [
          "rfid"
        ]
      }
    },
    {
      "command": "stop",
      "command_id": "req-001",
      "payload": {
        "scanType": [
          "ble"
        ]
      }
    },
    {
      "command": "stop",
      "command_id": "req-001",
      "payload": {
        "scanType": [
          "ble",
          "rfid"
        ]
      }
    }
  ]
}
