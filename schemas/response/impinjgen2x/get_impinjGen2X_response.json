{
  "title": "Get Impinj Gen2X Configuration Response",
  "type": "object",
  "description": "Returns the current Impinj Gen2X feature configuration.",
  "properties": {
    "command": {
      "type": "string",
      "enum": [
        "get_impinjGen2X"
      ],
      "example": "get_impinjGen2X"
    },
    "command_id": {
      "type": "string",
      "example": "gen2x-get-001"
    },
    "response": {
      "type": "string",
      "enum": [
        "success",
        "failure"
      ],
      "example": "success"
    },
    "payload": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "fastID": {
              "type": "object",
              "properties": {
                "enabled": {
                  "type": "boolean",
                  "example": true
                },
                "tidSelector": {
                  "type": "string",
                  "enum": [
                    "TID[0]",
                    "TID[1]",
                    "TID[2]",
                    "TID[3]"
                  ],
                  "example": "TID[0]"
                }
              },
              "required": [
                "enabled"
              ]
            },
            "tagProtect": {
              "type": "object",
              "properties": {
                "action": {
                  "type": "string",
                  "enum": [
                    "enableTagProtection",
                    "disableTagProtection",
                    "enableTagVisibility",
                    "disableTagVisibility"
                  ],
                  "example": "enableTagProtection"
                },
                "password": {
                  "type": "string",
                  "minLength": 8,
                  "maxLength": 8,
                  "pattern": "^[0-9A-Fa-f]{8}$",
                  "example": "77777777"
                },
                "tagID": {
                  "type": "string",
                  "pattern": "^[0-9A-Fa-f]+$",
                  "example": "e2801191a5030069073b426d"
                },
                "enableShortRange": {
                  "type": "boolean",
                  "example": true
                }
              },
              "required": [
                "action",
                "password"
              ]
            },
            "tagFocus": {
              "type": "object",
              "properties": {
                "enabled": {
                  "type": "boolean",
                  "example": true
                }
              },
              "required": [
                "enabled"
              ]
            },
            "tagQuieting": {
              "$ref": "../../references/shared/impinjTagQuieting.yaml"
            }
          },
          "additionalProperties": false
        },
        {
          "$ref": "../../references/response_payload/errors.yaml"
        }
      ]
    }
  },
  "required": [
    "command",
    "command_id",
    "response",
    "payload"
  ],
  "examples": [
    {
      "command": "get_impinjGen2X",
      "command_id": "gen2x-get-001",
      "response": "success",
      "payload": {
        "fastID": {
          "enabled": true,
          "tidSelector": "TID[0]"
        }
      }
    }
  ]
}
