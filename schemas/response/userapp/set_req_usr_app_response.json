{
  "title": "Send Command to User app",
  "x-stoplight": {
    "id": "v5hdpblsqhcym"
  },
  "type": "object",
  "description": "Sends the specified command to the specified user application",
  "properties": {
    "command": {
      "type": "string",
      "enum": [
        "set_req_usr_app"
      ],
      "example": "set_req_usr_app",
      "description": "The value for the key command must be set_req_usr_app"
    },
    "command_id": {
      "type": "string",
      "example": "abcd13212",
      "description": "A unique ID that will be echoed back in the command response by the reader."
    },
    "response": {
      "type": "string",
      "enum": [
        "success",
        "failure"
      ],
      "example": "success"
    },
    "payload": {
      "oneOf": [
        {
          "$ref": "../../references/response_payload/request_userapp_response.yaml"
        },
        {
          "$ref": "../../references/response_payload/errors.yaml"
        }
      ]
    }
  },
  "required": [
    "command",
    "command_id"
  ]
}
