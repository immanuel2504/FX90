{
  "title": "Set the Logging Config",
  "x-stoplight": {
    "id": "7uxvg5622unow"
  },
  "type": "object",
  "description": "modifies the logging configuration on the reader",
  "properties": {
    "command": {
      "type": "string",
      "enum": [
        "set_logs"
      ],
      "example": "set_logs",
      "description": "The value for the key command must be set_logs"
    },
    "command_id": {
      "type": "string",
      "example": "abcd2134234",
      "description": "A unique ID that will be echoed back in the command response by the reader."
    },
    "payload": {
      "title": "set_logs",
      "type": "object",
      "description": "Changes logging level",
      "properties": {
        "radioPacketLog": {
          "type": "boolean",
          "description": "Indicates whether radio packet logging is enabled."
        },
        "components": {
          "type": "array",
          "description": "Log level configuration per reader subcomponent.",
          "items": {
            "x-stoplight": {
              "id": "dmfpma3wqs07h"
            },
            "type": "object",
            "properties": {
              "componentName": {
                "x-stoplight": {
                  "id": "r6tsamn5i9kd7"
                },
                "description": "Name of subcomponent. For radio_control, only the INFO log level is supported. For reader_gateway, supported log levels are INFO, DEBUG, WARNING, and ERROR.",
                "type": "string",
                "enum": [
                  "radio_control",
                  "reader_gateway"
                ]
              },
              "level": {
                "type": "string",
                "x-stoplight": {
                  "id": "r2iynmvsj4e39"
                },
                "description": "Logging Level",
                "enum": [
                  "DEBUG",
                  "INFO",
                  "WARNING",
                  "ERROR"
                ]
              }
            },
            "required": [
              "componentName",
              "level"
            ]
          }
        }
      }
    }
  },
  "required": [
    "command",
    "command_id",
    "payload"
  ]
}
