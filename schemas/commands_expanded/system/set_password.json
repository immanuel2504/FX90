{
  "title": "Set Password",
  "type": "object",
  "description": "Changes the password on the reader.",
  "properties": {
    "command": {
      "type": "string",
      "enum": [
        "set_password"
      ],
      "example": "set_password",
      "description": "The value for the key command must be set_password"
    },
    "command_id": {
      "type": "string",
      "example": "password-set-001",
      "description": "A unique ID that will be echoed back in the command response by the reader."
    },
    "payload": {
      "type": "object",
      "properties": {
        "userName": {
          "type": "string",
          "description": "Reader login username.",
          "example": "admin"
        },
        "currentPassword": {
          "type": "string",
          "description": "Current password for the specified user.",
          "example": "change"
        },
        "newPassword": {
          "type": "string",
          "description": "New password to set for the specified user.",
          "example": "Mypass@123"
        }
      },
      "required": [
        "userName",
        "currentPassword",
        "newPassword"
      ]
    }
  },
  "required": [
    "command",
    "command_id",
    "payload"
  ],
  "examples": [
    {
      "command": "set_password",
      "command_id": "password-set-001",
      "payload": {
        "currentPassword": "change",
        "newPassword": "Mypass@123",
        "userName": "admin"
      }
    }
  ]
}
